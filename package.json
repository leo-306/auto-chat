{
  "name": "wechat-topic",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "files": [
    "apps/server/dist",
    "apps/server/public",
    "apps/extension/dist",
    "packages/shared/dist",
    "skills/auto-chat",
    "docs/agent-integration.md",
    "examples",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "bin": {
    "auto-chat": "apps/server/dist/cli.js"
  },
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build -w @wechat-topic/shared && npm run build -w @wechat-topic/extension && npm run build -w @wechat-topic/server",
    "check": "npm run build -w @wechat-topic/shared && npm run check --workspaces --if-present",
    "test": "npm run build -w @wechat-topic/shared && npm run test --workspaces --if-present",
    "dev:server": "npm run dev -w @wechat-topic/server",
    "auto-chat": "node apps/server/dist/cli.js",
    "job:add": "npm run cli -w @wechat-topic/server -- job:add",
    "job:list": "npm run cli -w @wechat-topic/server -- job:list",
    "job:show": "npm run cli -w @wechat-topic/server -- job:show",
    "job:watch": "npm run cli -w @wechat-topic/server -- job:watch",
    "job:listen": "npm run cli -w @wechat-topic/server -- job:listen",
    "job:dispatch": "npm run cli -w @wechat-topic/server -- job:dispatch",
    "job:doctor": "npm run cli -w @wechat-topic/server -- job:doctor",
    "job:retry": "npm run cli -w @wechat-topic/server -- job:retry",
    "job:open": "npm run cli -w @wechat-topic/server -- job:open"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "typescript": "^5.9.0"
  }
}
