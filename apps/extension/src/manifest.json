{
  "manifest_version": 3,
  "name": "auto-chat",
  "version": "0.1.0",
  "description": "接管本地任务队列，在 ChatGPT 中执行图片或文本任务并保存结果。",
  "permissions": ["tabs", "scripting", "storage", "downloads", "alarms", "clipboardRead"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "http://127.0.0.1:17321/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
  "default_title": "auto-chat",
    "default_popup": "popup.html"
  }
}
